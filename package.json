{
  "name": "dr1tch-presentations",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "typecheck": "pnpm --filter presentations-index typecheck",
    "build": "slidev build",
    "dev": "slidev --open",
    "export": "slidev export",
    "dev:copilot": "slidev decks/copilot.md --open",
    "build:copilot": "slidev build decks/copilot.md",
    "export:copilot": "slidev export decks/copilot.md",
    "build:all": "node scripts/build-all.mjs",
    "dev:index": "pnpm --filter presentations-index dev",
    "build:index": "pnpm --filter presentations-index build"
  },
  "dependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-apple-basic": "^0.25.1",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "eslint": "^9.11.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.8.1"
  }
}
